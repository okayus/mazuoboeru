    "check:e2e": "pnpm --filter @mazuoboeru/web check:e2e",
    "e2e": "pnpm --filter @mazuoboeru/web e2e"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": { "node": ">=20" }
}
