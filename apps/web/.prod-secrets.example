# Copy to .prod-secrets (gitignored), fill with PRODUCTION values, then run:
#   bash scripts/put-prod-secrets.sh      (or: pnpm secrets:prod)
#
# RUN ON THE HOST ONLY — never inside the dev sandbox, and never commit real
# values (ADR-0003 "secret-zero"). These are injected into the Worker as
# encrypted Secrets; the code references them by name only.

# ── Required (MVP is GitHub-only — ADR-0001) ────────────────────────────────
# GitHub OAuth App: one form at github.com/settings/applications/new (no review,
# no publishing). Authorization callback URL to register:
#   https://mazuoboeru.shiraoka.workers.dev/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Pepper mixed into PAT hashes: sha256(token + PAT_PEPPER). Any long random
# string, e.g. `openssl rand -base64 32`. SET ONCE — changing it later
# invalidates every existing PAT (apps/web/worker/auth/pat.ts).
PAT_PEPPER=

# ── Optional: Google (deferred — ADR-0001) ──────────────────────────────────
# Leave blank to stay GitHub-only. To add Google later: create an External
# "Web application" OAuth client (console-only) with redirect URI
#   https://mazuoboeru.shiraoka.workers.dev/auth/callback/google
# then set BOTH values below, re-run, and restore the Google button in
# apps/web/src/views/Login.tsx. (Set both or neither — one alone is ignored.)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
