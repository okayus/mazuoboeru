{
  "name": "@mazuoboeru/web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "deploy": "pnpm build && wrangler deploy",
    "check": "tsc --noEmit",
    "check:e2e": "tsc --noEmit -p e2e/tsconfig.json",
    "test": "vp test run",
    "db:migrate": "wrangler d1 migrations apply mazuoboeru-db --local",
    "db:migrate:prod": "wrangler d1 migrations apply mazuoboeru-db --remote",
    "secrets:prod": "bash scripts/put-prod-secrets.sh",
    "e2e": "playwright test",
    "e2e:db": "node e2e/seed.ts",
    "e2e:server": "pnpm build && pnpm run e2e:db && node e2e/prepare-config.ts && wrangler dev --config dist/mazuoboeru/wrangler.json --persist-to .wrangler/state-e2e --ip 127.0.0.1 --port 5399"
  },
  "dependencies": {
    "arctic": "^3.7.0",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.6.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "swr": "^2.4.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^0.1.0",
    "@cloudflare/workers-types": "^4.20250328.0",
    "@playwright/test": "1.60.0",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "wrangler": "^3.100.0"
  }
}
