{
  "name": "@mazuoboeru/web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "deploy": "pnpm build && wrangler deploy",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "db:migrate": "wrangler d1 migrations apply mazuoboeru-db --local",
    "db:migrate:prod": "wrangler d1 migrations apply mazuoboeru-db --remote",
    "secrets:prod": "bash scripts/put-prod-secrets.sh"
  },
  "dependencies": {
    "arctic": "^3.7.0",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.6.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "swr": "^2.4.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^0.1.0",
    "@cloudflare/workers-types": "^4.20250328.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.8",
    "wrangler": "^3.100.0"
  }
}
